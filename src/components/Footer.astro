---
const currentYear = new Date().getFullYear();
const footerSections = [
  {
    title: "Links",
    links: [
      { name: "Github", url: "https://github.com/soraimahiro/GDG-astro-theme" }
    ],
  },
  {
    title: "Reference",
    links: [
      { name: "Astro", url: "https://astro.build" },
      { name: "Tailwind CSS", url: "https://tailwindcss.com" }
    ],
  },
];
---

<footer class="w-full border-t border-[var(--color-surface)] bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-wrap justify-center gap-x-16 gap-y-10 mb-10">
      {
        footerSections.map((section) => (
          <div class="min-w-[120px]">
            <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-4 text-center md:text-left">
              {section.title}
            </h3>
            <ul class="space-y-3 text-center md:text-left">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="border-t border-[var(--color-surface)] pt-8 text-center">
      <p class="text-sm text-[var(--color-muted)]">
        &copy; {currentYear} GDG NTNU. All rights reserved.
      </p>
    </div>
  </div>
</footer>