---
<div class="w-full max-w-7xl mx-auto mb-5 flex items-center py-3 px-4 gap-3 rounded-b-xl bg-(--color-accent) text-lg text-(--color-bg)">

    <a href="/" class="group flex items-center gap-3 text-(--color-bg) hover:text-[var(--color-surface)] font-bold">
      <img src="/Logo.png" alt="Website Logo" class="size-10 rounded-full" />
      <span>Astro Theme Lion</span>
    </a>

    <a href="/allPosts" class="group flex relative py-2 cursor-pointer font-black text-(--color-bg) hover:text-[var(--color-surface)]">
        <span>All Post</span>
    </a>

    <div class="ml-auto flex items-center px-5 py-1 bg-[var(--color-surface)] focus-within:ring-3 focus-within:ring-[var(--color-accent)] rounded-lg">
      <input type="text" placeholder="Search..." class="bg-transparent border-none outline-none text-sm text-white placeholder-[var(--color-muted)] w-80" />
      <img src="/Search.png" alt="Search Icon" class="w-5 h-5" />
    </div>

</div>