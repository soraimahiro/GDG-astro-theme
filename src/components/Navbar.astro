---
<div class="w-full max-w-7xl mx-auto mb-8 flex items-center p-5 gap-5 rounded-b-xl bg-[var(--color-accent)] text-xl text-[var(--color-bg)] transition-colors">
    <a href="/" class="group flex items-center px-5 gap-5 text-[var(--color-bg)] hover:text-[var(--color-surface)] font-bold">
      <img src="/Logo.png" alt="Website Logo" class="w-12 h-12 rounded-full" />
      <span>Astro Theme Lion</span>
    </a>
    <a href="/allPosts" class="group flex relative py-2 cursor-pointer font-black text-[var(--color-bg)] hover:text-[var(--color-surface)]">
        <span>All Post</span>
    </a>
    <div class="ml-auto mr-5 flex items-center px-5 py-1 bg-[var(--color-surface)] focus-within:ring-3 focus-within:ring-[var(--color-accent)] rounded-lg">
      <input type="text" placeholder="Search..." class="bg-transparent border-none outline-none text-base text-white placeholder-[var(--color-muted)] w-80" />
      <img src="/Search.png" alt="Search Icon" class="w-5 h-5" />
    </div>
</div>