---
import { Icon } from 'astro-icon/components';

interface Props {
    prevTitle: string;
    nextTitle: string;

    prevPicture?: string; 
    nextPicture?: string;

    prevUrl: string;
    nextUrl: string;
}

const { 
    prevTitle, 
    nextTitle,

    prevPicture, 
    nextPicture,

    prevUrl, 
    nextUrl 
} = Astro.props;
---

<div class="flex justify-center w-full gap-3">
    <div class="rounded-xl bg-(--color-surface) p-3 flex-1">
            <!-- left area -->
            <a href={prevUrl} class="rounded-l-xl w-full flex items-center justify-start cursor-pointer px-6 gap-4 group">
                
                <!-- left arrow -->
                <Icon name="mingcute:left-line" class="size-12 filter group-hover:text-(--color-accent) transition"/>
                
                <!-- prevPicture -->
                {prevPicture && (
                    <div class="size-16 rounded-lg overflow-hidden border-2 border-(--color-surface)">
                    <img src={prevPicture} alt="Cover" class="shrink-0 size-full object-cover group-hover:scale-110 transition duration-500" />
                </div>
            )}
            
            <!-- prevText -->
            <div class="flex flex-col items-start text-left">
                <span class="text-sm text-(--color-muted) uppercase font-bold ">
                    PREV
                </span>
                <span class="text-lg font-bold text-white leading-tight group-hover:text-(--color-accent) transition">
                    {prevTitle}
                </span>
            </div>
        </a>
    </div>

    <div class="rounded-xl bg-(--color-surface) p-3 flex-1">
        <!-- right area -->
        <a href={nextUrl} class="rounded-r-xl w-full flex items-center justify-end cursor-pointer group px-6 gap-4">
            
            <!-- nextText -->
            <div class="flex flex-col items-end text-right">
                <span class="text-sm text-(--color-muted) uppercase font-bold">
                    Next
                </span>
                <span class="text-lg font-bold text-white leading-tight group-hover:text-(--color-accent) transition">
                    {nextTitle}
                </span>
            </div>
            
            <!-- nextPicture -->
            {nextPicture && (
                <div class="size-16 rounded-lg overflow-hidden border-2 border-(--color-surface)">
                    <img src={nextPicture} alt="Cover" class="shrink-0 size-full object-cover group-hover:scale-110 transition duration-500" />
                </div>
            )}

            <!-- right arrow -->
            <Icon name="mingcute:right-line" class="size-12 filter group-hover:text-(--color-accent) transition"/>
            
        </a>
    </div>
</div>