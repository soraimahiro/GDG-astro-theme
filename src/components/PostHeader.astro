---
import FormatDate from "../utils/FormatDate.astro";
import Tag from "./widgets/Tag.astro";

interface Props {
    title: string;
    pubDate: Date;
    tags: string[];
}

const { title, pubDate, tags } = Astro.props;
---
<div class="text-4xl text-white mb-2">
    {title}
</div>
<div class="text-lg font-normal tracking-wide text-[var(--color-muted)]">
    <FormatDate date={pubDate} />
</div>

<div class="flex gap-2 pb-2 mt-2 mb-5 border-b border-[var(--color-surface)]">
    {tags.map((tag) => (<Tag>{tag}</Tag>))}
</div>
