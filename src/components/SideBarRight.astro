---
import type { MarkdownHeading } from "astro";

interface Props {
    headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth <= 3);
---

<nav class="w-full flex-1 min-h-0 overflow-y-scroll pr-1 custom-scrollbar" data-toc-container>
    <ul class="space-y-2 border-l-2 border-(--color-muted) text-sm ">
        {
            toc.map((heading) => (
                <li>
                    <a href={`#${heading.slug}`}
                        class:list={[
                            "toc-link block py-1 transition-all",
                            heading.depth === 2 ? "pl-4" : "pl-8 text-xs",
                        ]}>
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<style>
  /* Custom scrollbar styling for the TOC container */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(207, 219, 213, 0.2);
    border-radius: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: var(--color-accent);
  }
  /* For Firefox */
  .custom-scrollbar {
    scrollbar-width: thin;
    scrollbar-color: rgba(207, 219, 213, 0.2) transparent;
  }
</style>

<script>
    function initTOC() {
        const headings = document.querySelectorAll("h1[id], h2[id], h3[id]");
        const offset = 120;
        let currentActiveId: string | null = null;
        let rafId = 0;

        const updateActiveHeading = () => {
            rafId = 0;

            const activeHeading = Array.from(headings).reduce<HTMLElement | null>(
                (candidate, heading) => {
                    const rect = heading.getBoundingClientRect();

                    if (rect.top <= offset) {
                        return heading as HTMLElement;
                    }

                    return candidate;
                },
                null
            );

            const targetHeading = activeHeading ?? (headings[0] as HTMLElement | undefined);
            const id = targetHeading?.getAttribute("id") ?? null;

            if (!id || id === currentActiveId) {
                return;
            }

            currentActiveId = id;

            document.querySelectorAll(".toc-link").forEach((link) => {
                link.classList.remove("active");
            });

            const activeLink = document.querySelector(`.toc-link[href="#${id}"]`);

            if (activeLink) {
                activeLink.classList.add("active");

                const tocContainer = document.querySelector(
                    "[data-toc-container]"
                );

                if (tocContainer) {
                    const containerRect = tocContainer.getBoundingClientRect();
                    const linkRect = activeLink.getBoundingClientRect();

                    const isAboveVisibleArea = linkRect.top < containerRect.top;
                    const isBelowVisibleArea = linkRect.bottom > containerRect.bottom;

                    if (isAboveVisibleArea || isBelowVisibleArea) {
                        activeLink.scrollIntoView({
                            block: "nearest",
                            behavior: "smooth",
                        });
                    }
                }
            }
        };

        const scheduleUpdate = () => {
            if (rafId !== 0) {
                return;
            }

            rafId = window.requestAnimationFrame(updateActiveHeading);
        };

        const setInitialActive = () => {
            updateActiveHeading();
        };

        window.addEventListener("scroll", scheduleUpdate, { passive: true });
        window.addEventListener("resize", scheduleUpdate);

        setInitialActive();
    }

    document.addEventListener("DOMContentLoaded", initTOC);
    document.addEventListener("astro:page-load", initTOC);
</script>
